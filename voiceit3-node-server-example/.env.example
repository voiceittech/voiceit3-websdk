# Copy to .env and fill in real values before running `node server.js`.
# .env should be gitignored.

# VoiceIt API credentials from https://voiceit.io
VOICEIT_THREE_API_KEY=
VOICEIT_THREE_API_TOKEN=
VOICEIT_TEST_USER_ID=

# Demo login — pick your own values; these are the only accepted
# credentials for the /login endpoint in this example.
DEMO_EMAIL=
DEMO_PASSWORD=

# REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Set to true when serving over HTTPS so session cookies are flagged Secure.
SESSION_COOKIE_SECURE=false

SESSION_EXPIRATION_TIME_HOURS=1
CONTENT_LANGUAGE=no-STT
